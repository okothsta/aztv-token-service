# Copy this file to .env in the same folder, then fill in the values.
# Never commit .env. The .gitignore in the repo already excludes it.

# Where the AZTV Token Service lives. No trailing slash.
SERVICE_URL=https://aztv-token-service.onrender.com

# Shared secret with the Render service. Set this same value as the
# PUSH_SECRET env var on Render.
PUSH_SECRET=

# AzamMax Bearer token from web.azamtvmax.com DevTools (the long string
# after "authorization: Bearer "). Lasts ~1 month.
BEARER=

# subscriptionDtl from the request payload — long base64 string.
SUBSCRIPTION_DTL=

# contentDtl from the request payload — long base64 string.
CONTENT_DTL=

# Optional. How often to mint a fresh magic JWT, in hours. Default 10
# (the magic JWT lives ~12h, so 10 leaves a 2h buffer).
REFRESH_HOURS=10

# Optional. How many times to retry on failure before giving up until next cycle.
RETRY_ATTEMPTS=4

# Optional. Backoff between retries, ms. Multiplied by attempt number (linear backoff).
RETRY_BACKOFF_MS=60000

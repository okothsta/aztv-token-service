# Copy this to a Render env var page (or .env locally). DO NOT commit .env.

# REQUIRED — admin login password for the admin panel.
# Pick something long and random. This is the ONLY person allowed to change credentials.
ADMIN_PASSWORD=replace-me-with-a-long-random-string

# REQUIRED — secret used to sign admin session cookies. Just a random 32+ char string.
SESSION_SECRET=replace-me-with-another-long-random-string

# REQUIRED — Firebase service account, JSON pasted as a single env var.
# In Render: paste the entire firebase-service-account.json file contents here.
# Or for local dev: leave this empty and put the file at ./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# OPTIONAL — refresh interval in hours. Default 10 (so we refresh well before
# the 12-hour upstream token expiry).
TOKEN_REFRESH_HOURS=10

# OPTIONAL — port. Render sets this automatically; leave empty.
PORT=
